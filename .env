OPENAI_API_KEY= #Paste API key here 
DB_PATH=outputs/newsletter.csv
EXPERIMENT_PROFILE=low #low, medium, or full
SOURCE_MAX_CANDIDATES=10
VERBOSE_LOGGING=true
TRACE_ARTICLES=true
RESET_STORAGE_ON_RUN=true #If RESET_STORAGE_ON_RUN=true, each run clears CSV first, so no accumulation. If RESET_STORAGE_ON_RUN=false, new processed rows are appended, so digest can include previous + new items.